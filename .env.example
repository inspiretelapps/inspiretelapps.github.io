# Convex Backend URL
# Get this from your Convex dashboard after running `npx convex dev`
# Example: https://robust-poodle-492.convex.cloud
VITE_CONVEX_URL=your_convex_deployment_url

# Exa API Key for MCP Server
# Get your API key from: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_exa_api_key_here
